# Copie para .env e preencha com seus valores reais
# NUNCA faça commit do .env no repositório

# URL RPC da Sepolia (ex: via Alchemy ou Infura)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/SUA_API_KEY

# Chave privada da carteira de deploy (sem o prefixo 0x)
PRIVATE_KEY=sua_chave_privada_aqui

# API Key do Etherscan para verificação de contratos
ETHERSCAN_API_KEY=sua_etherscan_api_key

# Exibir relatório de gas nos testes
REPORT_GAS=false
